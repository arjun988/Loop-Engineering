{
  "name": "loop-mcp",
  "version": "0.1.0",
  "description": "MCP server for automated loop engineering in AI coding workflows",
  "main": "dist/index.js",
  "bin": {
    "loop-mcp": "dist/index.js",
    "loop-worker": "dist/worker.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ai",
    "coding",
    "automation",
    "loop-engineering"
  ],
  "author": "Loop Engineering Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/loop-engineering"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "cron-parser": "^4.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
